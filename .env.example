# Spotify API Credentials (https://developer.spotify.com/dashboard adresinden alınabilir)
# OAuth gerekmez, Client Credentials Flow kullanılacaktır.
SPOTIPY_CLIENT_ID=your_spotify_client_id_here
SPOTIPY_CLIENT_SECRET=your_spotify_client_secret_here

# Yapay Zeka API Ayarları (Örn: OpenAI, Anthropic, Gemini vb. OpenAI uyumlu API'ler)
# Varsayılan olarak OpenAI uyumlu bir API yapısı kurulmuştur.
LLM_API_KEY=your_llm_api_key_here
LLM_API_URL=https://api.openai.com/v1/chat/completions
LLM_MODEL=gpt-4o-mini
